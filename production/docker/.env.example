# ═══════════════════════════════════════════════════════════
# VARIABLES D'ENTORN - PRODUCCIÓ
# Copia a .env i omple amb els teus valors reals
# ═══════════════════════════════════════════════════════════

# ── App ──
APP_NAME="Campanya Consultoria Digital"
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=genera-una-clau-segura-de-64-chars-aqui

# ── Base de dades ──
DB_PASSWORD=la_teva_contrasenya_postgres_segura
DATABASE_URL=postgresql+asyncpg://campanya:${DB_PASSWORD}@db:5432/campanya_crm

# ── Redis ──
REDIS_PASSWORD=la_teva_contrasenya_redis_segura
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2

# ── Email (SendGrid) ──
# Registra't a https://sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=campanya@edutac.es
EMAIL_FROM_NAME=Impulsa el teu Negoci Digital
LEAD_NOTIFICATION_EMAIL=bandujar@edutac.es

# ── IA: Anthropic (Agents) ──
# Aconsegueix la clau a https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
AI_MODEL_CHAT=claude-sonnet-4-5-20250929
AI_MODEL_AGENTS=claude-sonnet-4-5-20250929

# ── IA: Google Gemini (Imatges Nano Banana) ──
# Aconsegueix la clau a https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL_IMAGES=gemini-2.5-flash-image

# ── Auth (JWT) ──
JWT_SECRET_KEY=genera-una-altra-clau-segura-per-jwt
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ── Observabilitat ──
# Registra't a https://sentry.io
SENTRY_DSN=https://xxxx@sentry.io/xxxx
LOG_LEVEL=INFO

# ── CORS ──
CORS_ORIGINS=["https://impulsa.edutac.es","http://localhost:3000"]

# ── Idioma per defecte ──
DEFAULT_LANGUAGE=ca
